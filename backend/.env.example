# Robolearn Backend Configuration

# App
APP_NAME=Robolearn API
DEBUG=False

# Security
SECRET_KEY=your-secret-key-change-in-production-robolearn
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=robolearn_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=robolearn

# MongoDB
MONGODB_URL=mongodb://mongo:27017
MONGODB_DB=robolearn_metrics

# Dialogflow (optional - set these if you have Google Cloud credentials)
DIALOGFLOW_PROJECT_ID=
DIALOGFLOW_AGENT_ID=
GOOGLE_CREDENTIALS_PATH=

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173", "http://localhost:8000"]

# Node Environment
NODE_ENV=development
