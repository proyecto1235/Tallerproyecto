# ============================================
# RoboLearn — Configuración completa
# Copia este archivo como .env y completa los valores
# ============================================

# -------------------------------------------
# BACKEND (backend/.env)
# -------------------------------------------

# App
APP_NAME=Robolearn API
DEBUG=True
NODE_ENV=development

# Seguridad — ¡cambia esto en producción!
SECRET_KEY=dev-secret-key-change-in-production-robolearn
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=robolearn

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=robolearn_metrics

# ---- DIALOGFLOW (Chatbot) ----
# El chatbot usa Google Cloud Dialogflow.
# Necesitas:
#   1. Un proyecto en Google Cloud
#   2. Un agente de Dialogflow ES creado
#   3. Una cuenta de servicio con credenciales JSON

# ID del proyecto de Google Cloud
DIALOGFLOW_PROJECT_ID=tu-project-id-aqui

# ID del agente de Dialogflow (lo encuentras en la consola de Dialogflow)
DIALOGFLOW_AGENT_ID=tu-agent-id-aqui

# Ruta al archivo JSON de la clave privada de la cuenta de servicio
# Puedes dejarlo vacío si usas GOOGLE_APPLICATION_CREDENTIALS directamente
GOOGLE_CREDENTIALS_PATH=./robolearn-key.json

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:8000"]

# -------------------------------------------
# FRONTEND (frontend/.env y frontend/.env.local)
# -------------------------------------------

# URL base de la API
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Expiración del JWT (días)
NEXT_PUBLIC_JWT_EXPIRATION_DAYS=7

# JWT Secret (debe coincidir con el SECRET_KEY del backend)
JWT_SECRET=dev-secret-key-change-in-production-robolearn
