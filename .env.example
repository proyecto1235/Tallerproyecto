# ============================================
# RoboLearn — Configuración completa
# Copia este archivo como .env y completa los valores
# NUNCA commitees el archivo .env real
# ============================================

# -------------------------------------------
# SECRETOS CRÍTICOS — ¡DEBES CAMBIARLO EN PRODUCCIÓN!
# -------------------------------------------
# Genera un SECRET_KEY fuerte con: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=
JWT_SECRET=${SECRET_KEY}

# -------------------------------------------
# App
# -------------------------------------------
APP_NAME=Robolearn API
DEBUG=false
NODE_ENV=production

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
# Para RS256 (recomendado en producción):
# Genera: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
# Luego pega las claves en JWT_PRIVATE_KEY y JWT_PUBLIC_KEY
# ALGORITHM se ajusta automáticamente a RS256 cuando ambas claves están presentes
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# -------------------------------------------
# PostgreSQL
# -------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=robolearn

# -------------------------------------------
# MongoDB
# -------------------------------------------
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=robolearn_metrics
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=

# -------------------------------------------
# Redis
# -------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# -------------------------------------------
# Ollama / Local LLM
# -------------------------------------------
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:1.5b

# -------------------------------------------
# Dialogflow (Chatbot)
# -------------------------------------------
DIALOGFLOW_PROJECT_ID=
DIALOGFLOW_AGENT_ID=
GOOGLE_CREDENTIALS_PATH=

# -------------------------------------------
# CORS — Lista de orígenes permitidos
# -------------------------------------------
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# -------------------------------------------
# Frontend
# -------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
