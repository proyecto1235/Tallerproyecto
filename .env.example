# ============================================
# RoboLearn — Variables de Entorno
# Copia este archivo como .env y completa los valores
# ¡NUNCA subas el .env real al repositorio!
# ============================================

# -------------------------------------------
# BACKEND — App
# -------------------------------------------
APP_NAME=Robolearn API
APP_ENV=development
DEBUG=True

# Seguridad — CAMBIA esto en producción
SECRET_KEY=changeme-para-produccion-robolearn
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
# Para RS256 (recomendado en producción):
# Genera: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
# Luego pega las claves en JWT_PRIVATE_KEY y JWT_PUBLIC_KEY
# ALGORITHM se ajusta automáticamente a RS256 cuando ambas claves están presentes
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# -------------------------------------------
# BACKEND — PostgreSQL
# -------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme-postgres-password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=robolearn
DB_POOL_MIN=5
DB_POOL_MAX=50

# -------------------------------------------
# BACKEND — MongoDB
# -------------------------------------------
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=robolearn_metrics

# -------------------------------------------
# BACKEND — Redis (opcional — si no hay, usa degradación graceful)
# -------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -------------------------------------------
# BACKEND — Ollama (IA local)
# -------------------------------------------
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:1.5b

# -------------------------------------------
# BACKEND — OpenAI (fallback opcional, solo si Ollama no responde)
# -------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo

# -------------------------------------------
# BACKEND — Dialogflow (opcional)
# -------------------------------------------
DIALOGFLOW_PROJECT_ID=
DIALOGFLOW_AGENT_ID=
GOOGLE_CREDENTIALS_PATH=

# -------------------------------------------
# BACKEND — ML Models
# -------------------------------------------
ML_MODEL_DIR=models

# -------------------------------------------
# BACKEND — CORS
# -------------------------------------------
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# -------------------------------------------
# FRONTEND
# -------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_JWT_EXPIRATION_DAYS=7

# Debe coincidir con SECRET_KEY del backend
JWT_SECRET=changeme-para-produccion-robolearn